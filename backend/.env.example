# Copy to .env and adjust. Never commit real secrets.

GEMINI_API_KEY=
# Override with GEMINI_MODEL in .env (default in code: gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Minimum characters for documentText on /api/analyze
MIN_DOCUMENT_CHARS=80
